# Repository-level .gitignore for the Unity project in /MegaRaketa.
#
# Keep this file in the repository root. Because the Unity project is inside
# the MegaRaketa folder, Unity-generated directories below must use the
# /MegaRaketa/ prefix. If the Unity project is moved to the repository root,
# remove that prefix from the Unity section.

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Editor and IDE local files
.idea/
.vscode/
.vs/
*.suo
*.tmp
*.user
*.userprefs
*.DotSettings.user

# Logs
*.log
*.stackdump

# Unity generated folders for /MegaRaketa
/MegaRaketa/[Ll]ibrary/
/MegaRaketa/[Tt]emp/
/MegaRaketa/[Oo]bj/
/MegaRaketa/[Bb]uild/
/MegaRaketa/[Bb]uilds/
/MegaRaketa/[Ll]ogs/
/MegaRaketa/[Uu]ser[Ss]ettings/
/MegaRaketa/[Mm]emoryCaptures/
/MegaRaketa/[Rr]ecordings/
/MegaRaketa/.utmp/
/MegaRaketa/.gradle/
/MegaRaketa/[Ee]xported[Oo]bj/
/MegaRaketa/.consulo/

# Unity-generated solution and project files
/MegaRaketa/*.csproj
/MegaRaketa/*.unityproj
/MegaRaketa/*.sln
/MegaRaketa/*.slnx
/MegaRaketa/*.pidb
/MegaRaketa/*.booproj
/MegaRaketa/*.svd
/MegaRaketa/*.pdb
/MegaRaketa/*.mdb
/MegaRaketa/*.opendb
/MegaRaketa/*.VC.db
/MegaRaketa/*.pidb.meta
/MegaRaketa/*.pdb.meta
/MegaRaketa/*.mdb.meta

# Unity crash and diagnostics files
/MegaRaketa/sysinfo.txt
/MegaRaketa/mono_crash.*
/MegaRaketa/crashlytics-build.properties

# Unity builds and exported packages
*.apk
*.aab
*.app
*.unitypackage
*.unitypackage.meta

# Blender backup files imported by Unity are not needed in version control
*.blend1
*.blend1.meta

# Autogenerated JetBrains Rider plugin inside the Unity project
/MegaRaketa/[Aa]ssets/Plugins/Editor/JetBrains*

# TestRunner generated files
/MegaRaketa/[Ii]nit[Tt]est[Ss]cene*.unity*
/MegaRaketa/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Addressables generated data
/MegaRaketa/ServerData/
/MegaRaketa/[Aa]ssets/StreamingAssets/aa*
/MegaRaketa/[Aa]ssets/AddressableAssetsData/link.xml*
/MegaRaketa/[Aa]ssets/Addressables_Temp*
/MegaRaketa/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting generated files
/MegaRaketa/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/MegaRaketa/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/MegaRaketa/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/MegaRaketa/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated cache in Assets folder
/MegaRaketa/[Aa]ssets/[Ss]ceneDependencyCache*

# Optional Asset Store tools. Uncomment if this package is imported locally.
# /MegaRaketa/[Aa]ssets/AssetStoreTools*
